<?xml version="1.0"?>
<ruleset name="phpDivingLog">
  <description>PSR-12 checks for modernized phpDivingLog source.</description>

  <file>src</file>
  <file>adapters</file>
  <file>config</file>
  <file>tests</file>

  <rule ref="PSR12"/>
  <rule ref="Generic.Files.LineLength">
    <severity>0</severity>
  </rule>

  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/var/*</exclude-pattern>
</ruleset>

{
  "name": "phpdivinglog/phpdivinglog",
  "description": "Modernized phpDivingLog core and adapters",
  "type": "project",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.3",
    "twig/twig": "^3.12"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.2",
    "phpstan/phpstan": "^1.11",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "PhpDivingLog\\": "src/",
      "PhpDivingLog\\Adapters\\": "adapters/"
    },
    "classmap": [
      "adapters/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "PhpDivingLog\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "stan": "phpstan analyse --memory-limit=512M",
    "cs": "phpcs"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

{% extends 'layout.html.twig' %}

{% block content %}
  <section class="dive-overview-panel">
    <div class="dive-overview-head">
      <h2>Shops</h2>
    </div>

    <div class="table-wrap">
      <table class="dives-table" data-dives-table data-sortable>
        <thead>
          <tr>
            <th scope="col">Shop</th>
          </tr>
        </thead>
        <tbody>
          {% for shop in shops %}
            <tr data-href="/shops/{{ shop.id }}" tabindex="0" role="link" aria-label="Open shop {{ shop.name }}">
              <td><a href="/shops/{{ shop.id }}">{{ shop.name }}</a></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <script src="/assets/js/tables.js" defer></script>
{% endblock %}

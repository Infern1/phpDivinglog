{% if pages|default(1) > 1 %}
  {% set paginationBasePath = basePath|default('/') %}
  <nav class="dive-pagination" aria-label="Pagination">
    {% for page in 1..pages %}
      <a href="{{ paginationBasePath }}?page={{ page }}{% if search is defined and search != '' %}&q={{ search|url_encode }}{% endif %}{% if sort is defined and sort != '' %}&sort={{ sort|url_encode }}{% endif %}"{% if page == currentPage %} aria-current="page"{% endif %}>{{ page }}</a>
    {% endfor %}
  </nav>
{% endif %}
